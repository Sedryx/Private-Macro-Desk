generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MEMBER
}

enum AssetType {
  STOCK
  ETF
  INDEX
  FOREX
  CRYPTO
  COMMODITY
  RATE
}

enum Bias {
  BULLISH
  BEARISH
  NEUTRAL
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  PLANNED
  OPEN
  CLOSED
  CANCELLED
}

enum DailyTrend {
  BULLISH
  BEARISH
  RANGE
}

enum EntryZone {
  EMA50_PULLBACK
  SUPPORT_RESISTANCE
  FIB_RETRACEMENT
  NONE
}

enum EntrySignal {
  ENGULFING
  PIN_BAR
  RSI_OVERSOLD
  RSI_OVERBOUGHT
  NONE
}

enum MacroCategory {
  RATES
  INFLATION
  LABOR
  GROWTH
  PMI
  CENTRAL_BANK
  OTHER
}

enum EventImportance {
  LOW
  MEDIUM
  HIGH
}

enum DocumentType {
  PDF
  FILING
  NOTE
  ARTICLE
  OTHER
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String?
  role              UserRole           @default(MEMBER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  watchlists        Watchlist[]
  trades            Trade[]
  tradeNotes        TradeNote[]
  researchDocuments ResearchDocument[]
}

model Asset {
  id             String          @id @default(cuid())
  symbol         String
  name           String
  type           AssetType
  exchange       String?
  currency       String?
  country        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  watchlistItems WatchlistItem[]
  trades         Trade[]

  @@unique([symbol, type])
  @@index([symbol])
}

model Watchlist {
  id        String          @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]
}

model WatchlistItem {
  id             String    @id @default(cuid())
  watchlistId    String
  assetId        String
  bias           Bias?
  notes          String?
  importantLevel String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  watchlist      Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, assetId])
  @@index([assetId])
}

model Trade {
  id           String         @id @default(cuid())
  userId       String
  assetId      String
  direction    TradeDirection
  status       TradeStatus    @default(PLANNED)
  entryPrice   Decimal?
  stopLoss     Decimal?
  takeProfit   Decimal?
  riskPercent  Decimal?
  thesis       String
  invalidation String?
  result       String?
  mistakeTags  String[]       @default([])
  strategyCode String?
  dailyTrend   DailyTrend?
  entryZone    EntryZone?
  entrySignal  EntrySignal?
  setupValid   Boolean        @default(false)
  openedAt     DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset        Asset          @relation(fields: [assetId], references: [id], onDelete: Restrict)
  notes        TradeNote[]

  @@index([userId])
  @@index([assetId])
}

model TradeNote {
  id              String   @id @default(cuid())
  tradeId         String
  userId          String
  content         String
  screenshotUrls  String[] @default([])
  clientRequestId String?  @unique
  createdAt       DateTime @default(now())
  trade           Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([userId])
}

model MacroIndicator {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  country   String?
  category  MacroCategory
  unit      String?
  source    String?
  releaseType      String?
  providerUpdatedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  values    MacroValue[]
}

model MacroValue {
  id          String         @id @default(cuid())
  indicatorId String
  date        DateTime
  value       Decimal
  createdAt   DateTime       @default(now())
  indicator   MacroIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, date])
  @@index([date])
}

model EconomicEvent {
  id            String          @id @default(cuid())
  externalId    String?
  provider      String?
  title         String
  country       String?
  currency      String?
  importance    EventImportance
  eventTime     DateTime
  previousValue String?
  forecastValue String?
  actualValue   String?
  expectedImpact String?
  source        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([eventTime])
  @@unique([provider, externalId])
}

model ResearchDocument {
  id           String          @id @default(cuid())
  externalId   String?
  provider     String?
  country      String?
  ticker       String?
  companyName  String?
  formType     String?
  filedAt      DateTime?
  reportDate   DateTime?
  sourceUrl    String?
  secItems     String[]        @default([])
  exhibits     Json?
  importance   String?
  category     String?
  summary      String?
  title        String
  type         DocumentType
  source       String?
  fileUrl      String?
  uploadedById String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  uploadedBy   User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  chunks       ResearchChunk[]

  @@index([provider])
  @@index([country])
  @@index([ticker])
  @@index([filedAt])
  @@index([formType])
  @@index([importance])
  @@unique([provider, externalId])
}

model ResearchChunk {
  id         String           @id @default(cuid())
  documentId String
  content    String
  pageNumber Int?
  createdAt  DateTime         @default(now())
  document   ResearchDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model WorkspaceSettings {
  id            String   @id @default(cuid())
  workspaceName String   @default("Private Macro Desk")
  language      String   @default("en")
  timezone      String   @default("Europe/Zurich")
  baseCurrency  String   @default("USD")
  theme         String   @default("dark")
  accentColor   String   @default("green")
  fontSize      String   @default("normal")
  density       String   @default("compact")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
