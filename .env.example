# Copy this file to .env and fill in the values below.
# For docker-compose, DATABASE_URL is overridden automatically for the app
# service (it points at the "postgres" service, not localhost) — the value
# here is only used for local (non-Docker) `npm run dev`.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/private_macro_desk"

# Random string used to sign session tokens (src/lib/auth/token.ts). Generate
# one with: openssl rand -base64 32
AUTH_SECRET=""

# --- Macro data (FRED, dashboard, FX volatility) ---
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=""

# --- Economic calendar ---
FOREX_FACTORY_CALENDAR_URL="https://nfs.faireconomy.media/ff_calendar_thisweek.json"

# --- AI (daily brief + Research key takeaways) ---
# Optional — without a key, the AI brief and key takeaways stay empty and
# everything else works normally.
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-3.1-flash-lite"   # optional, this default is already used if unset

# --- Research SEC EDGAR (optional, manual sync only: npm run data:research:sec) ---
# The default automatic sync (Fed + ECB) doesn't need any of these.
SEC_USER_AGENT=""
SEC_RESEARCH_TICKERS="AAPL,MSFT,NVDA,TSLA,META,AMZN,GOOGL"
SEC_RESEARCH_FORMS="10-K,10-Q,8-K,DEF 14A"
SEC_RESEARCH_LIMIT_PER_TICKER="12"

# --- Docker only: automated DB backup interval (see docker-compose.yml) ---
# Accepts GNU sleep-style durations, e.g. 4h, 1d, 7d.
BACKUP_INTERVAL="1d"

# --- Docker only: which published image tag to pull (see docker-compose.yml) ---
# IMAGE_TAG="v1-alpha"
